@page "/"
@attribute [AllowAnonymous]
@using SessionNotebook.Pages.Campaigns

<b>Welcome to SessionNotebook!</b><br/>

<AuthorizeView>
    <Authorized>
        Create or select a campaign to get started.
        <h3 class="mt-3">Campaigns</h3>
        <CampaignList/>
    </Authorized>
    <NotAuthorized>
        Log in to get started.
    </NotAuthorized>
</AuthorizeView>

@code {
    [CascadingParameter]
    public MainLayout Layout { get; set; }

    protected override void OnInitialized()
    {
        Layout.Title = "Home";
    }
}
