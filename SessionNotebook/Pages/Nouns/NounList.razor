@page "/nounList/{campaignId:int}"
@using DataLayer.Entities
@using SessionNotebook.Data
@using SessionNotebook.Services
@inject NavigationManager Navigation
@inject HistoryStack History
@inject CampaignService CampaignService
@inject NounService NounService
@inject TagService TagService
@inject NotebookState State

@if (_nouns == null)
{
    <LoadingPlaceholder/>
}
else if (_nouns.Any() || _isSearching)
{
    <ListSearchBar AddEntity="@AddNoun" ListEntities="@ListNouns" CreateDefaultCriteria="@CreateDefaultCriteria"
                   Tags="@_nounTags" SortFields="@(["Name", "Notes", "UpdatedAt"])"
                   ShowAddButton="@IsCampaignLevel">

        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">Synopsis</th>
                    <th scope="col">Description</th>
                    <th scope="col"># Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var noun in _nouns)
                {
                    <tr>
                        <th scope="row"><a href="/noun/@noun.Id">@noun.Name</a></th>
                        <td>@GridFormatter.Format(noun.Synopsis)</td>
                        <td>@GridFormatter.Format(noun.Description)</td>
                        <td>@noun.NoteCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </ListSearchBar>
}
else
{
    <button class="btn btn-primary mb-2" @onclick="AddNoun">+ New</button>
    <p>
        <em>You have no Nouns yet!</em>
    </p>
}

@code {
    private List<Noun> _nouns;
    private List<Tag> _nounTags;
    private bool _isSearching;

    private bool IsFullPage => Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("nounList");
    private bool IsTagLevel => TagId.HasValue;
    private bool IsCampaignLevel => !IsTagLevel;

    [CascadingParameter]
    public MainLayout Layout { get; set; }

    [Parameter]
    public int CampaignId { get; set; }

    [Parameter]
    public int? TagId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (IsFullPage)
        {
            Layout.Title = "Nouns";
            History.Push(Navigation);
        }

        await State.EnsureCampaignLoaded(CampaignService, campaignId: CampaignId);
        await ListNouns();

        if (IsCampaignLevel)
        {
            _nounTags = await TagService.ListAllTags(CampaignId, typeof(Noun));
        }
    }

    private void AddNoun()
    {
        State.InitializeNewNoun(CampaignId);
        Navigation.NavigateTo("noun/new");
    }

    private async Task<int> ListNouns(SearchCriteria searchCriteria = null)
    {
        if (IsTagLevel)
        {
            searchCriteria ??= CreateDefaultCriteria();
            searchCriteria.TagId = TagId!.Value;
        }

        var searchResults = await NounService.ListNouns(CampaignId, searchCriteria);
        _nouns = searchResults.Results;
        _isSearching = searchCriteria != null;
        StateHasChanged();

        return searchResults.PageCount;
    }

    private static SearchCriteria CreateDefaultCriteria()
    {
        return new SearchCriteria { SortBy = "Name", IsSortAscending = true };
    }
}
