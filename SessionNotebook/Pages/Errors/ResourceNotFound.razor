@page "/NotFound"
@layout MainLayout

<p role="alert" class="alert alert-danger lead">
    <i class="oi oi-warning px-1" aria-hidden="true"></i>
    Whoops, there's nothing at this address.
</p>

@code {
    [CascadingParameter]
    public MainLayout Layout { get; set; }

    protected override void OnInitialized()
    {
        Layout.Title = "Not found";
    }
}
