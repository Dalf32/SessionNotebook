<i class="@IconClass" title="@Text" aria-hidden="@(!IsCollapsed)"></i>
@if (!IsCollapsed)
{
    <b>@Text</b>
}

@code {
    [Parameter]
    public string IconClass { get; set; }
    
    [Parameter]
    public string Text { get; set; }
    
    [Parameter]
    public bool IsCollapsed { get; set; }
}